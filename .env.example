# ── Firebase ────────────────────────────────────────────────────────────────
# Console: https://console.firebase.google.com → seu projeto → Project Settings → SDK config
VITE_FIREBASE_API_KEY="AIzaSy..."
VITE_FIREBASE_AUTH_DOMAIN="seu-projeto.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="seu-projeto"
VITE_FIREBASE_STORAGE_BUCKET="seu-projeto.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:0000000000000000"
VITE_FIREBASE_DATABASE_ID="(default)"

# ── Contato ──────────────────────────────────────────────────────────────────
VITE_WHATSAPP_PHONE="5591993170497"
VITE_CONTACT_EMAIL="contato@inovapro3d.com.br"

# GEMINI_API_KEY: optional. Used by AI features when enabled.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: public URL where this app is hosted.
# Used for self-referential links, callbacks and API endpoints when needed.
APP_URL="MY_APP_URL"

# DISABLE_HMR: set to true to disable Vite HMR/file watching in constrained environments.
DISABLE_HMR="false"

# MODEL_IMPORT_ALLOWED_HOSTS: comma-separated host allowlist for product metadata imports.
MODEL_IMPORT_ALLOWED_HOSTS="makerworld.com,bambulab.com,bambulab.cn"

# ── Telegram (notificações de pedido) ───────────────────────────────────────
# Crie um bot em https://t.me/BotFather → /newbot → copie o token
# Para obter o chat_id: envie uma mensagem ao bot e acesse
#   https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN="123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TELEGRAM_CHAT_ID="123456789"

# ── Stripe (pagamento) ───────────────────────────────────────────────────────
# Deixe em branco para desativar o Stripe — o fluxo manual de PIX permanece ativo.
# Crie sua conta em https://dashboard.stripe.com/register e copie as chaves.
VITE_STRIPE_PUBLIC_KEY="pk_live_..."        # chave pública (frontend) — segura de expor
STRIPE_SECRET_KEY="sk_live_..."             # chave secreta (servidor) — NUNCA exponha
STRIPE_WEBHOOK_SECRET="whsec_..."           # gerado ao criar o webhook no dashboard Stripe
