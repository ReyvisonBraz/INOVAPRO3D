rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY HELPERS
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function authEmail() { return request.auth.token.email; }

    // Auth tokens do not use custom claims in this project. Roles are stored in users/{uid}.
    function isAdmin() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ADMIN";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function changedKeys() { return incoming().diff(existing()).affectedKeys(); }
    function optionalString(value, maxSize) {
      return value == null || (value is string && value.size() <= maxSize);
    }
    function optionalNumber(value) {
      return value == null || value is number;
    }

    function isValidUser(data) {
      return data.email is string &&
             data.role is string &&
             data.role in ['CUSTOMER', 'ADMIN', 'OPERATOR'] &&
             data.keys().hasAll(['email', 'role', 'createdAt']);
    }

    function isValidCustomerUserCreate(data) {
      return isValidUser(data) &&
             data.keys().hasOnly(['email', 'name', 'photoURL', 'role', 'createdAt', 'loyaltyPoints']) &&
             data.email == authEmail() &&
             data.role == 'CUSTOMER' &&
             data.createdAt == request.time &&
             (!('loyaltyPoints' in data) || data.loyaltyPoints == 0) &&
             optionalString(data.name, 160) &&
             optionalString(data.photoURL, 2048);
    }

    function isValidProfileSelfUpdate() {
      return changedKeys().hasOnly(['name', 'phone', 'addresses', 'photoURL']) &&
             optionalString(incoming().name, 160) &&
             optionalString(incoming().phone, 32) &&
             optionalString(incoming().photoURL, 2048);
    }

    function isValidAdminUserUpdate() {
      return changedKeys().hasOnly(['role', 'loyaltyPoints', 'name', 'phone', 'addresses', 'photoURL']) &&
             isValidUser(incoming()) &&
             optionalString(incoming().name, 160) &&
             optionalString(incoming().phone, 32) &&
             optionalString(incoming().photoURL, 2048) &&
             optionalNumber(incoming().loyaltyPoints);
    }

    function isValidTicketCreate(data) {
      return data.keys().hasOnly(['userId', 'userName', 'email', 'phone', 'subject', 'message', 'status', 'createdAt']) &&
             data.keys().hasAll(['subject', 'message', 'status', 'createdAt']) &&
             data.subject is string && data.subject.size() >= 3 && data.subject.size() <= 160 &&
             data.message is string && data.message.size() >= 10 && data.message.size() <= 4000 &&
             data.status == 'OPEN' &&
             data.createdAt == request.time &&
             optionalString(data.userId, 128) &&
             optionalString(data.userName, 160) &&
             optionalString(data.email, 254) &&
             optionalString(data.phone, 32);
    }

    function isValidOrderCreate(data) {
      return data.keys().hasOnly(['userId', 'userName', 'userEmail', 'items', 'total', 'shippingAddress', 'status', 'createdAt']) &&
             data.keys().hasAll(['userId', 'items', 'total', 'shippingAddress', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             optionalString(data.userName, 160) &&
             optionalString(data.userEmail, 254) &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.total is number && data.total >= 0 &&
             data.shippingAddress is map &&
             data.status == 'PENDING_PAYMENT' &&
             data.createdAt == request.time;
    }

    function isValidQuoteCreate(data) {
      return data.keys().hasOnly(['userId', 'userName', 'userEmail', 'status', 'fileName', 'materialId', 'infill', 'estimatedPrice', 'createdAt']) &&
             data.keys().hasAll(['userId', 'status', 'fileName', 'materialId', 'infill', 'createdAt']) &&
             data.userId == request.auth.uid &&
             optionalString(data.userName, 160) &&
             optionalString(data.userEmail, 254) &&
             data.status == 'PENDING' &&
             data.fileName is string && data.fileName.size() >= 1 && data.fileName.size() <= 120 &&
             isValidId(data.materialId) &&
             data.infill is number && data.infill >= 0 && data.infill <= 100 &&
             optionalNumber(data.estimatedPrice) &&
             data.createdAt == request.time;
    }

    function isValidCategory(data) {
      return data.name is string &&
             data.name.size() >= 1 &&
             data.name.size() <= 80 &&
             data.keys().hasAll(['name', 'createdAt']) &&
             optionalString(data.slug, 80) &&
             optionalString(data.parentId, 128) &&
             optionalString(data.image, 2048) &&
             optionalString(data.description, 500) &&
             data.active is bool;
    }

    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

    // USERS
    match /users/{userId} {
      allow get: if isOwner(userId) || (isSignedIn() && isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidCustomerUserCreate(incoming());
      allow update: if (isOwner(userId) && isValidProfileSelfUpdate()) ||
                    (isSignedIn() && isAdmin() && isValidAdminUserUpdate());
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SHOWCASE
    match /showcase/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // MATERIALS
    match /materials/{materialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(incoming());
      allow update: if isAdmin();
    }

    // COUPONS
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CUSTOMERS
    match /customers/{customerId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // TICKETS
    match /tickets/{ticketId} {
      allow read: if isAdmin();
      allow create: if isValidTicketCreate(incoming());
      allow update, delete: if isAdmin();
    }

    // FAQS
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SETTINGS
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // LOGS
    match /logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (isSignedIn() && isValidOrderCreate(incoming()));
      allow write: if isAdmin();
    }

    // QUOTES
    match /quotes/{quoteId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (isSignedIn() && isValidQuoteCreate(incoming()));
      allow write: if isAdmin();
    }
  }
}
