rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ SECURITY HELPERS
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Auth tokens never contain custom claims. We lookup roles in the users collection.
    function isAdmin() { 
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ADMIN";
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.email is string && 
             data.role is string && 
             data.role in ['CUSTOMER', 'ADMIN', 'OPERATOR'] &&
             data.keys().hasAll(['email', 'role', 'createdAt']);
    }

    // 🔒 DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

    // 👤 USERS
    match /users/{userId} {
      // Allow get for self or admin
      allow get: if isOwner(userId) || (isSignedIn() && isAdmin());
      
      // Allow creation of profile by the user themselves
      allow create: if isSignedIn() && isOwner(userId) && 
                     isValidUser(incoming()) && 
                     (incoming().role == "CUSTOMER" || (incoming().role == "ADMIN" && incoming().email == "littlefigther50@gmail.com")) &&
                     incoming().createdAt == request.time;
      
      // Allow updates to non-critical fields for self, or ADMIN role for specific user
      allow update: if (isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'addresses', 'photoURL']) ||
        (incoming().role == "ADMIN" && incoming().email == "littlefigther50@gmail.com")
      )) || (isSignedIn() && isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'loyaltyPoints', 'name', 'phone', 'addresses', 'photoURL']));
    }

    // 📦 PRODUCTS
    match /products/{productId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin();
    }

    // 🖼️ SHOWCASE
    match /showcase/{itemId} {
      allow read: if true; // Public showcase
      allow write: if isAdmin();
    }

    // 🧵 MATERIALS
    match /materials/{materialId} {
      allow read: if true; // Public materials
      allow write: if isAdmin();
    }

    // 🎫 COUPONS
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 👥 CUSTOMERS
    match /customers/{customerId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 🎫 TICKETS
    match /tickets/{ticketId} {
      allow read: if isAdmin();
      allow create: if true; // Public can create tickets via contact form
      allow update, delete: if isAdmin();
    }

    // ❓ FAQS
    match /faqs/{faqId} {
      allow read: if true; // Public FAQ
      allow write: if isAdmin();
    }

    // ⚙️ SETTINGS
    match /settings/{settingId} {
      allow read: if true; // Public needs to know global ship times etc
      allow write: if isAdmin();
    }

    // 📜 LOGS
    match /logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // 💳 ORDERS
    match /orders/{orderId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isAdmin();
    }

    // 📂 QUOTES
    match /quotes/{quoteId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
